FROM {{ original_image }}

# Terminus-2 deps: tmux + script (bsdutils) + asciinema
# Best-effort install — these are non-critical for envd functionality.
# Many task images have broken apt/dpkg state by design, so we must tolerate failures.
RUN set +e; \
    if command -v apk >/dev/null 2>&1; then \
        apk add --no-cache tmux asciinema util-linux procps 2>/dev/null; \
    else \
        export DEBIAN_FRONTEND=noninteractive && \
        dpkg --configure -a 2>/dev/null || true && \
        mv /etc/apt/sources.list.d /etc/apt/sources.list.d.bak 2>/dev/null || true && \
        mkdir -p /etc/apt/sources.list.d && \
        (apt-get update && \
         apt-get install -y --no-install-recommends --fix-broken tmux asciinema bsdutils) 2>/dev/null || true && \
        rm -rf /etc/apt/sources.list.d && \
        mv /etc/apt/sources.list.d.bak /etc/apt/sources.list.d 2>/dev/null || true && \
        rm -rf /var/lib/apt/lists/*; \
    fi; \
    exit 0

# Copy envd binary (e2b infra daemon)
COPY envd /usr/local/bin/envd
RUN chmod +x /usr/local/bin/envd

EXPOSE 49983

# Wrap the real sleep binary so that "command: [sleep, inf]" from k8s
# transparently starts envd before sleeping.
# Locate sleep dynamically (busybox: /bin/sleep, debian: /usr/bin/sleep)
RUN SLEEP_PATH=$(command -v sleep) && \
    mv "$SLEEP_PATH" "${SLEEP_PATH}.real" && \
    printf '#!/bin/sh\nif ! pgrep -x envd >/dev/null 2>&1; then\n  envd -port 49983 -isnotfc &\nfi\nexec "%s.real" "$@"\n' "$SLEEP_PATH" > "$SLEEP_PATH" && \
    chmod +x "$SLEEP_PATH"

# Keep entrypoint.sh for non-k8s / local docker run usage
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
